# Variables
@api_url = http://localhost:8080/api/v1

### Health check
GET {{api_url}}/health

### Login organizer 1 (seeded)
# @name login_organizer
POST {{api_url}}/auth/login
Content-Type: application/json

{
    "email": "organizer1@example.com",
    "password": "Password123!"
}

### Login attendee 1 (seeded)
# @name login_attendee1
POST {{api_url}}/auth/login
Content-Type: application/json

{
    "email": "attendee1@example.com",
    "password": "Password123!"
}

# Store access token from the last login response
@access_token_organizer = {{login_organizer.response.body.$.access_token}}
@access_token_attendee1 = {{login_attendee1.response.body.$.access_token}}

### Get me
GET {{api_url}}/me
Authorization: Bearer {{access_token_attendee1}}

### Create event
POST {{api_url}}/events
Content-Type: application/json
Authorization: Bearer {{access_token_organizer}}

{
    "title": "Javascript Conference 2026",
    "description": "Javascript Conference 2026 is a conference about the Javascript programming language",
    "location": "Amsterdam, Netherlands",
    "starts_at": "2026-03-11T10:00:00Z",
    "ends_at": "2026-03-11T11:00:00Z",
    "capacity": 1000
}

### Get all events
# @name get_all_events
GET {{api_url}}/events
Authorization: Bearer {{access_token_attendee1}}

# Get first page of events (limit 10)
### Get paginated events
GET {{api_url}}/events?limit=10&offset=0
Authorization: Bearer {{access_token_attendee1}}

# Store event ID from the last get all events response
@event_id = {{get_all_events.response.body.$[0].id}}

### Get event by ID
GET {{api_url}}/events/{{event_id}}
Authorization: Bearer {{access_token_attendee1}}

### Create booking
# @name create_booking
POST {{api_url}}/events/{{event_id}}/bookings
Authorization: Bearer {{access_token_attendee1}}

# Store booking ID from the last create booking response
@booking_id = {{create_booking.response.body.$.id}}

### Get my bookings
GET {{api_url}}/bookings
Authorization: Bearer {{access_token_attendee1}}

### Cancel booking
DELETE {{api_url}}/bookings/{{booking_id}}
Authorization: Bearer {{access_token_attendee1}}
